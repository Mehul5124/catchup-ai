# ──────────────────────────────────────────────────────────────────────────
#  CatchUp AI – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# Google Gemini API key (get yours at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Tells the app to use mock data instead of real API calls
CATCHUP_MODE=mock

# (Optional) Vertex AI settings – leave blank for AI Studio / API key mode
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=False
